<% content_for :title, "Batches — LabelCheck" %>

<div class="wrap" data-controller="refresh" data-refresh-active-value="<%= @batches.any?(&:active?) %>">
  <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap">
    <div>
      <h1 class="page-title">Batches</h1>
      <p class="page-sub" style="margin-bottom:0">Bulk label verification jobs. This list refreshes while any batch is running.</p>
    </div>
    <div class="actions">
      <%= link_to "Single Label", new_review_path, class: "btn btn-secondary" %>
      <%= link_to "New Batch", new_batch_path, class: "btn" %>
    </div>
  </div>

  <div class="card" style="margin-top:20px" data-refresh-region>
    <% if @batches.empty? %>
      <p class="center muted" style="margin:24px 0">No batches yet. <%= link_to "Upload your first batch", new_batch_path %>.</p>
    <% else %>
      <div class="table-scroll">
        <table class="data">
          <thead>
            <tr>
              <th>Batch</th>
              <th>Created</th>
              <th>Status</th>
              <th>Progress</th>
              <th>Failed</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @batches.each do |batch| %>
              <tr>
                <td>#<%= batch.id %></td>
                <td><%= batch.created_at.strftime("%b %-d, %Y %-l:%M %p") %></td>
                <td><span class="badge badge-<%= batch.status %>"><%= batch.status %></span></td>
                <td><%= batch.progress_label %></td>
                <td><%= batch.failed_count.positive? ? batch.failed_count : "—" %></td>
                <td><%= link_to "View", batch_path(batch) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
