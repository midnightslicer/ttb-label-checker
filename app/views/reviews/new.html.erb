<% content_for :title, "Check a Label — LabelCheck" %>

<div class="wrap">
  <h1 class="page-title">Check a Single Label</h1>
  <p class="page-sub">Upload a label image and the application values. We'll extract the label text and compare it field by field.</p>

  <div class="card">
    <%= form_with model: @review, url: reviews_path, method: :post, local: true do |f| %>
      <% if @review.errors.any? %>
        <div class="flash flash-alert">
          <%= @review.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="field">
        <%= f.label :label_image, "Label Image" %>
        <%= render layout: "shared/dropzone", locals: { hint: "JPG, PNG, or WEBP of the label" } do %>
          <%= f.file_field :label_image, accept: "image/*", required: true,
                class: "dropzone-input", data: { dropzone_target: "input" } %>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :app_brand_name, "Brand Name" %>
        <%= f.text_field :app_brand_name %>
      </div>

      <div class="field">
        <%= f.label :app_class_type, "Class / Type" %>
        <span class="hint">e.g. Kentucky Straight Bourbon Whiskey</span>
        <%= f.text_field :app_class_type %>
      </div>

      <div class="field">
        <%= f.label :app_abv, "Alcohol Content" %>
        <span class="hint">e.g. 45% Alc./Vol. (90 Proof)</span>
        <%= f.text_field :app_abv %>
      </div>

      <div class="field">
        <%= f.label :app_net_contents, "Net Contents" %>
        <span class="hint">e.g. 750 mL</span>
        <%= f.text_field :app_net_contents %>
      </div>

      <div class="field">
        <%= f.label :app_producer, "Producer Name & Address" %>
        <%= f.text_field :app_producer %>
      </div>

      <div class="field">
        <%= f.label :app_country_of_origin do %>
          Country of Origin <span class="optional">(optional)</span>
        <% end %>
        <%= f.text_field :app_country_of_origin %>
      </div>

      <%= f.submit "Check Label", class: "btn btn-block" %>
    <% end %>
  </div>
</div>
