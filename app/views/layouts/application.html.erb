<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "LabelCheck — TTB Compliance Checker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <header class="topbar">
      <div class="inner">
        <%= link_to root_path, class: "brand" do %>
          <span class="logo" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 6 9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="brand-text">
            <strong>LabelCheck</strong>
            <span>TTB Compliance Checker</span>
          </span>
        <% end %>

        <nav class="nav">
          <% if authenticated? %>
            <%= link_to "Single Label", new_review_path, class: ("active" if controller_name == "reviews") %>
            <%= link_to "Batch Upload", new_batch_path, class: ("active" if controller_name == "batches" && action_name != "index") %>
            <%= link_to "Batches", batches_path, class: ("active" if controller_name == "batches" && action_name == "index") %>
            <%= button_to "Sign out", logout_path, method: :delete, class: "nav-signout" %>
          <% else %>
            <%= link_to "Sign in", login_path, class: "nav-cta" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main>
      <% if notice %><div class="wrap" style="padding-bottom:0"><div class="flash flash-notice"><%= notice %></div></div><% end %>
      <% if alert %><div class="wrap" style="padding-bottom:0"><div class="flash flash-alert"><%= alert %></div></div><% end %>
      <%= yield %>
    </main>

    <footer class="site">
      <div class="inner">
        <span class="footer-brand">LabelCheck</span>
        <span>A TTB compliance checker tool. Label images are analyzed and compared
        against your submitted application values. Not affiliated with or endorsed by
        any government agency.</span>
      </div>
    </footer>
  </body>
</html>
