# ---- Ollama (local vision model) ----
OLLAMA_URL=http://host.docker.internal:11434
VISION_MODEL=gemma3:12b
# Small text model that matches extracted label text against the application.
MATCH_MODEL=gemma3:4b
# Per-request timeout in seconds (vision models can be slow on cold start)
OLLAMA_TIMEOUT=120

# ---- Rails ----
RAILS_ENV=production
# Generate with: bin/rails secret
SECRET_KEY_BASE=
RAILS_LOG_TO_STDOUT=true
RAILS_MAX_THREADS=5
# Run Solid Queue inside the Puma process (single-container deployments)
SOLID_QUEUE_IN_PUMA=1

# ---- Optional ----
MAX_BATCH_SIZE=300
