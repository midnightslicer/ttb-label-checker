# ---- Ollama (local vision model) ----
OLLAMA_URL=http://host.docker.internal:11434
VISION_MODEL=gemma3:12b
# Small text model that matches extracted label text against the application.
MATCH_MODEL=gemma3:4b
# Per-request timeout in seconds (vision models can be slow on cold start)
OLLAMA_TIMEOUT=120

# ---- Rails ----
RAILS_ENV=production
# Generate with: bin/rails secret
SECRET_KEY_BASE=
RAILS_LOG_TO_STDOUT=true
RAILS_MAX_THREADS=5
# Run Solid Queue inside the Puma process (single-container deployments)
SOLID_QUEUE_IN_PUMA=1

# ---- Upload authentication ----
# Credentials required to reach the upload pages.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# ---- Cloudflare Turnstile (login challenge) ----
# Leave both blank to disable the challenge (e.g. local development).
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Optional ----
MAX_BATCH_SIZE=300
